%% ====================================================================
%% Diagram 5: Spatial Planning Pipeline
%% How Mason decides WHERE to place objects: client pre-computation + server zones + tool fallback.
%% ====================================================================
flowchart TD
    classDef client fill:#3b82f6,stroke:#1d4ed8,color:#fff
    classDef server fill:#22c55e,stroke:#15803d,color:#fff
    classDef ai     fill:#f97316,stroke:#c2410c,color:#fff
    classDef algo   fill:#8b5cf6,stroke:#6d28d9,color:#fff

    subgraph CLIENTCOMP["Client-Side — Pre-request (useAICommand.ts)"]
        VP["Viewport Bounds\nfrom canvasStore\n{x, y, width, height} in canvas coords"]
        OBJ["All Board Objects\nfrom objectStore"]
        CSP["computeSuggestedPositions\nspatialPlanning.ts (client export)"]

        subgraph PASS1["Pass 1 — Viewport Scan"]
            P1A["Grid cluster scan inside viewport\nfind first empty anchor point\nstep by object dimensions"]
            P1B["Emit up to 5 positions\nlabeled source: 'viewport'"]
        end

        subgraph PASS2["Pass 2 — Reflow Fallback"]
            P2A["If viewport is full:\nlocate bottom of existing content\nplace in a vertical column below"]
            P2B["Emit positions\nlabeled source: 'reflow'"]
        end

        SPOS["5 Suggested Positions\n{x, y, width, height, source}\nattached to POST body"]
        COORD["Coordinate System\ncanvas space (unbounded, can be negative)\nscreenX = (canvasX - stageX) * stageScale\nAll final coords snap to 20px grid"]
    end

    subgraph SERVERCOMP["Server-Side — route.ts after JWT verify"]
        BS["boardState from POST body\nobjects[] + viewportBounds"]
        COZ["computeOccupiedZones\nspatialPlanning.ts (server export)"]

        subgraph ZONEBUILD["Zone Construction"]
            ZB1["Frames → exact AABB\n+ 20px padding on all sides"]
            ZB2["Non-frame objects → proximity cluster\n100px merge threshold\n+ 20px padding"]
            ZB3["Connectors → SKIPPED\nno spatial claim"]
        end

        ZONES["Occupied Zones Block\n≤ 20 compact zone rects\ninjected into Tier 2 system prompt"]

        subgraph TIER1PATH["Tier 1 Direct Placement"]
            FCR["findClearRect\nfor each object in Haiku result"]
            ROWSCAN["Row-major raster scan\nstep = max(40, dimension/4)\nsnap result to 20px grid\nunbounded search — never fails"]
        end
    end

    subgraph MASONTOOL["Mason Tool — At Inference Time"]
        FAS["findAvailableSpace tool\nparams: width, height, preferredArea?"]
        FASREAD["reads boardState closure\nno Firestore I/O — pure computation"]
        FASRESULT["Returns {x, y, width, height}\nfor use in subsequent create calls"]
    end

    subgraph DECISION["Mason Placement Decision"]
        DEC1["Simple command (1-3 objects)\nUse suggestedPositions from prompt\nor occupied zones to avoid collisions"]
        DEC2["Complex layout (4+ objects)\nCall findAvailableSpace FIRST\nthen create in batch or flowchart"]
        SNAP["All coordinates snapped\nto 20px grid before Firestore write"]
    end

    VP --> CSP
    OBJ --> CSP
    CSP --> PASS1
    CSP --> PASS2
    PASS1 --> P1A --> P1B --> SPOS
    PASS2 --> P2A --> P2B --> SPOS
    COORD -.->|"reference for conversion"| CSP

    SPOS -->|"attached to POST body"| SERVERCOMP

    BS --> COZ
    COZ --> ZONEBUILD
    ZB1 --> ZONES
    ZB2 --> ZONES
    ZB3 -.->|"skipped"| ZONES

    ZONES -->|"injected into Tier 2\nsystem prompt header"| DEC1

    BS --> TIER1PATH
    FCR --> ROWSCAN --> DEC1

    FAS --> FASREAD --> FASRESULT --> DEC2

    DEC1 --> SNAP
    DEC2 --> SNAP

    class VP,OBJ,CSP,P1A,P1B,P2A,P2B,SPOS,COORD client
    class BS,COZ,ZB1,ZB2,ZB3,ZONES,FCR,ROWSCAN server
    class FAS,FASREAD,FASRESULT ai
    class DEC1,DEC2,SNAP algo


