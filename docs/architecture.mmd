%% ====================================================================
%% Diagram 2: AI Command Flow (Sequence Diagram)
%% Full lifecycle from user typing a command to objects appearing on all canvases.
%% ====================================================================
sequenceDiagram
    participant User
    participant ChatInput as "ChatInput.tsx"
    participant useAICmd as "useAICommand"
    participant ZStore as "Zustand Stores"
    participant APIRoute as "POST /api/ai-command"
    participant Claude as "Claude LLM"
    participant Firestore as "Firestore DB"
    participant RTDB as "Realtime Database"
    participant Others as "Other Clients"

    User->>ChatInput: types command, presses Enter
    ChatInput->>useAICmd: sendAICommand(message, objectRefs)

    useAICmd->>ZStore: read clarificationPending flag
    Note over useAICmd: if pending, capture last 6 messages as turn history

    useAICmd->>ZStore: read objectStore + canvasStore (board state)
    Note over useAICmd: computeSuggestedPositions(objects, viewport)\nPass 1 viewport scan, Pass 2 reflow fallback

    useAICmd->>ZStore: create optimistic ai_command message (chatStore)
    useAICmd->>RTDB: write pending stream entry at aiStreams/{commandId}

    useAICmd->>APIRoute: POST body={message, boardState, suggestedPositions,\naiCommandId, messages[], viewportBounds} + Bearer JWT

    APIRoute->>Firestore: verifyIdToken via Firebase Admin JWKS

    alt JWT invalid or missing
        APIRoute-->>useAICmd: HTTP 401 Unauthorized
        useAICmd->>ZStore: set message.aiStatus = error
    else rate limit exceeded (aiCommandsToday)
        APIRoute->>Firestore: read BoardMetadata.aiCommandsToday
        APIRoute-->>useAICmd: HTTP 429 Too Many Requests
        useAICmd->>ZStore: set message.aiStatus = rate-limited
    else Tier 1 — direct command (1-3 objects)
        APIRoute->>Claude: generateObject via Haiku (classifyAndExtract)\ndiscriminated union schema
        Claude-->>APIRoute: structured result with positions
        APIRoute->>APIRoute: computeOccupiedZones + findClearRect per object
        APIRoute->>Firestore: batch write objects (isAIPending: false, full opacity)
        Firestore-->>Others: onSnapshot fires, objects appear immediately
        APIRoute-->>useAICmd: SSE stream — plain text summary
        useAICmd->>ZStore: save ai_response with objectReferences
        useAICmd->>Firestore: persist ai_response message
    else Tier 2 — planned command (4+ objects, flowcharts)
        APIRoute->>APIRoute: computeOccupiedZones(boardState)\nbuildTier2SystemPrompt with zones block + viewport
        APIRoute->>Claude: streamText with Sonnet 4.6\nstopWhen: stepCountIs(30), experimental_telemetry ON

        loop Tool calling (up to 30 steps)
            Claude->>Claude: select next tool call
            Claude->>APIRoute: tool request (createStickyNote / createShape / createFlowchart / etc.)
            APIRoute->>Firestore: write BoardObject (isAIPending: true, 50% opacity)
            Firestore-->>Others: onSnapshot fires
            Others->>Others: render pending object at 50% opacity
            APIRoute-->>Claude: tool result {success, objectId}
            Note over APIRoute: onStepFinish logs step + toolName to RTDB progress
        end

        loop SSE token streaming
            Claude-->>APIRoute: text token (summary line)
            APIRoute-->>useAICmd: SSE chunk
            useAICmd->>RTDB: relay chunk (100ms debounce via rtdbDebounceRef)
            RTDB-->>Others: onChildChanged fires
            Others->>Others: append to AIStreamMessage in ChatTimeline
        end

        APIRoute-->>useAICmd: stream ends (X-Tier: 2 header)
        useAICmd->>Firestore: confirmAIPendingObjects — batch update isAIPending=false
        Firestore-->>Others: onSnapshot fires (full opacity)
        useAICmd->>ZStore: find objects by aiCommandId, build objectReferences
        useAICmd->>ZStore: save ai_response message with objectReferences
        useAICmd->>Firestore: persist ai_response message (with objectReferences)
    end

    alt askClarification tool called by Mason
        Note over Claude,APIRoute: Mason outputs sentinel "Clarification needed: {question}"
        APIRoute-->>useAICmd: SSE stream ends with sentinel text
        useAICmd->>ZStore: set clarificationPending = true
        useAICmd->>ZStore: save ai_response with sentinel content
        Note over User: chat button shows pulsing amber dot
        User->>ChatInput: types clarifying answer
        Note over useAICmd: wasPendingClarification=true triggers\nturn history inclusion in next POST
    end

    alt Error during streaming or tool execution
        useAICmd->>Firestore: deleteObjectsByAiCommand(aiCommandId) — rollback
        useAICmd->>ZStore: set message.aiStatus = error, show error state
        useAICmd->>RTDB: clear pending stream entry
    end


